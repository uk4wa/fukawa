APP_NAME=pet-uk4wa

LOG_FORMAT=json
LOG_LEVEL=INFO

# --- Resource Server / OAuth 2.1 ---
# Keycloak issuer URL — exactly the value emitted in the 'iss' claim, including the realm.
# Example: https://auth.example.com/realms/pet
KEYCLOAK__ISSUER_URL=http://localhost:8080/realms/ukawa-pet

# Optional internal issuer URL for service-to-Keycloak HTTP calls when the
# public issuer hostname is not reachable from the app runtime (e.g. Docker).
KEYCLOAK__INTERNAL_ISSUER_URL=http://keycloak:8080/realms/ukawa-pet

# This service's Keycloak client_id (also surfaces resource_access roles).
KEYCLOAK__CLIENT_ID=pet-backend

# Acceptable audiences for the access token (JSON list). Validation accepts
# any of these in the 'aud' claim OR in 'azp'. The client_id is added
# automatically; you do not need to repeat it here.
KEYCLOAK__AUDIENCE=["pet-backend"]

# Allowed JWS algorithms (JSON list). Asymmetric only — never include 'none' or HS*.
KEYCLOAK__ALLOWED_ALGORITHMS=["RS256"]

# JWKS cache TTL (seconds). Background re-fetch beyond this; on unknown 'kid'
# we also force-refresh (rate-limited) to handle key rotation.
KEYCLOAK__JWKS_CACHE_TTL_SECONDS=300

# Allowed clock skew (seconds) for exp/nbf/iat.
KEYCLOAK__LEEWAY_SECONDS=30

# HTTP timeout for OIDC discovery / JWKS fetch (seconds).
KEYCLOAK__HTTP_TIMEOUT_SECONDS=5

# --- Database ---
DB__DRIVER="postgresql+asyncpg"
DB__HOST=localhost
DB__NAME=sts
DB__USER=admin
DB__PASSWORD=admin
DB__PORT=5432

ENGINE__ECHO=False
ENGINE__POOL_SIZE=10
ENGINE__MAX_OVERFLOW=20
ENGINE__POOL_PRE_PING=True

SESSION_MAKER__EXPIRE_ON_COMMIT=False
SESSION_MAKER__AUTOFLUSH=True

# --- Keycloak server (only needed for the local docker-compose dev stack) ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_DB_NAME=keycloak_db
KC_DB_USER=keycloak_user
KC_DB_PASSWORD=keycloak_password
KC_HOSTNAME=localhost
KC_LOG_LEVEL=INFO
